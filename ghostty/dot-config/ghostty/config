# Appearance
font-family                = "JetBrainsMono Nerd Font Mono"
font-size                  = 12
theme                      = Sonokai
title                      = " "
macos-icon                 = chalkboard
macos-titlebar-proxy-icon  = hidden
macos-titlebar-style       = hidden

## General Features

shell-integration-features = ssh-env,no-title
desktop-notifications      = true

# Quick Terminal
keybind                           = global:cmd+semicolon=toggle_quick_terminal
quick-terminal-position           = center
quick-terminal-size               = 55%,55%
quick-terminal-screen             = macos-menu-bar
quick-terminal-animation-duration = 0.75

