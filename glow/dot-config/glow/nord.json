{
  "document": {
    "color": "#D8DEE9",
    "background_color": "#2E3440",
    "margin": 2
  },
  "block_quote": {
    "color": "#81A1C1",
    "italic": true,
    "indent": 1,
    "indent_token": "│ "
  },
  "paragraph": {
    "color": "#D8DEE9"
  },
  "list": {
    "color": "#D8DEE9",
    "level_indent": 2
  },
  "item": {
    "color": "#D8DEE9",
    "block_prefix": "• "
  },
  "enumeration": {
    "color": "#88C0D0"
  },
  "h1": {
    "color": "#88C0D0",
    "background_color": "#3B4252",
    "bold": true,
    "prefix": "# ",
    "margin_bottom": 1
  },
  "h2": {
    "color": "#88C0D0",
    "bold": true,
    "prefix": "## "
  },
  "h3": {
    "color": "#81A1C1",
    "bold": true,
    "prefix": "### "
  },
  "h4": {
    "color": "#81A1C1",
    "prefix": "#### "
  },
  "h5": {
    "color": "#8FBCBB",
    "prefix": "##### "
  },
  "h6": {
    "color": "#8FBCBB",
    "prefix": "###### "
  },
  "strong": {
    "color": "#EBCB8B",
    "bold": true
  },
  "emph": {
    "color": "#A3BE8C",
    "italic": true
  },
  "hr": {
    "color": "#4C566A"
  },
  "code": {
    "color": "#A3BE8C",
    "background_color": "#3B4252"
  },
  "code_block": {
    "color": "#A3BE8C",
    "background_color": "#3B4252",
    "margin": 1
  },
  "link": {
    "color": "#88C0D0",
    "underline": true
  },
  "link_text": {
    "color": "#88C0D0"
  },
  "image": {
    "color": "#B48EAD"
  },
  "image_text": {
    "color": "#B48EAD",
    "italic": true
  },
  "table": {
    "color": "#D8DEE9"
  },
  "definition_list": {
    "color": "#D8DEE9"
  },
  "definition_term": {
    "color": "#88C0D0",
    "bold": true
  },
  "definition_description": {
    "color": "#D8DEE9",
    "italic": true
  },
  "task": {
    "ticked": "[x] ",
    "unticked": "[ ] "
  }
}
